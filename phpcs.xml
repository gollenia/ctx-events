<?xml version="1.0"?>
<ruleset name="Contexis Events Ruleset">
  <description>Custom PHPCS rules for the Contexis Events plugin</description>

  <!-- Verzeichnisse, die geprüft werden sollen -->
  <file>includes</file>
  <exclude-pattern>vendor/*</exclude-pattern>
  <exclude-pattern>node_modules/*</exclude-pattern>

  <!-- 1. Ein Basestandard, damit PHPCS überhaupt was hat -->
  <rule ref="PSR12" />

  <!-- 2. Eigene Regeln -->
  <rule ref="Generic.PHP.ForbiddenFunctions">
    <properties>
      <property name="forbiddenFunctions" type="array">
        <element key="var_dump" value="Use a logger instead."/>
        <element key="print_r" value="Use a logger instead."/>
      </property>
    </properties>
  </rule>

  <rule ref="Generic.Files.LineLength">
    <properties>
      <property name="lineLimit" value="140"/>
    </properties>
  </rule>

  <rule ref="Generic.Classes.DuplicateClassName"/>
  <rule ref="Generic.Arrays.ArrayIndent"/>
  <rule ref="Generic.ControlStructures.InlineControlStructure">
    <severity>0</severity>
  </rule>
  <rule ref="Generic.ControlStructures.DisallowYodaConditions"/>

  <rule ref="Generic.CodeAnalysis.AssignmentInCondition" />
  <rule ref="Generic.CodeAnalysis.EmptyPHPStatement" />
  <rule ref="Generic.CodeAnalysis.EmptyStatement" />
  <rule ref="Generic.CodeAnalysis.UnconditionalIfStatement" />
  <rule ref="Generic.CodeAnalysis.UnnecessaryFinalModifier" />
  <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter" />
  <rule ref="Generic.CodeAnalysis.UselessOverridingMethod" />
    
</ruleset>