{
	"version": "7.0.0",
	"name": "events",
	"description": "A WordPress plugin to manage events.",
	"scripts": {
		"build": "wp-scripts build --config webpack.config.js",
		"start": "wp-scripts start --config webpack.config.js",
		"make-pot": "wp i18n make-pot . languages/events.pot --slug=events --domain=events --exclude=node_modules,src",
		"make-json": "wp i18n make-json languages/ --no-purge",
		"packages-update": "wp-scripts packages-update"
	},
	"dependencies": {
		"@contexis/use-api-fetch": "^1.0.4",
		"@contexis/wp-react-form": "^1.1.6",
		"@wordpress/api-fetch": "^7.40.0",
		"@wordpress/icons": "^11.7.0",
		"clsx": "^2.1.1",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@types/wordpress__block-editor": "^15.0.3",
		"@types/wordpress__blocks": "^15.10.0",
		"@types/wordpress__data": "^6.0.2",
		"@wordpress/interactivity": "^6.40.0",
		"@wordpress/scripts": "^31.5.0"
	}
}
