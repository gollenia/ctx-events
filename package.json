{
	"$schema": "https://www.schemastore.org/package.json",
	"version": "1.0.0",
	"name": "ctx-events",
	"description": "A WordPress plugin to manage events.",
	"author": {
		"email": "thomas@kids-team.at",
		"name": "Thomas Gollenia"
	},
	"license": "GPL-3.0",
	"scripts": {
		"ts:generate": "php bin/typescript-transformer.php",
		"build": "npm run ts:generate && wp-scripts build --config webpack.config.js",
		"start": "npm run ts:generate && wp-scripts start --config webpack.config.js",
		"test:e2e": "playwright test",
		"make-pot": "wp i18n make-pot . languages/ctx-events.pot --slug=ctx-events --domain=ctx-events --exclude=node_modules,src",
		"make-json": "wp i18n make-json languages/ --no-purge",
		"packages-update": "wp-scripts packages-update"
	},
	"overrides": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@contexis/use-api-fetch": "^1.0.4",
		"@contexis/wp-react-form": "^2.0.0",
		"@tiptap/pm": "^3.20.4",
		"@tiptap/react": "^3.20.4",
		"@tiptap/starter-kit": "^3.20.4",
		"@wordpress/api-fetch": "^7.43.0",
		"@wordpress/icons": "^12.1.0",
		"clsx": "^2.1.1",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@playwright/test": "^1.58.2",
		"@types/wordpress__block-editor": "^15.0.5",
		"@types/wordpress__blocks": "^15.10.0",
		"@types/wordpress__core-data": "^2.4.5",
		"@types/wordpress__data": "^6.0.2",
		"@types/wordpress__editor": "^14.3.1",
		"@wordpress/interactivity": "^6.40.0",
		"@wordpress/scripts": "^31.8.0"
	}
}
