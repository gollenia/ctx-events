		"@wordpress/icons": "^10.32.0",
		"classnames": "^2.5.1",
		"qs": "^6.14.0",
		"react-inlinesvg": "^4.2.0",
		"uuid": "^12.0.0"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.27.0"
	}
