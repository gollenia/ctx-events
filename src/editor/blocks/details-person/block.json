{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/details-person",
	"apiVersion": 3,
	"title": "Event Person",
	"description": "Show the event person",
	"category": "widgets",
	"attributes": {
		"showPortrait": {
			"type": "boolean",
			"default": true
		},
		"icon": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"showLink": {
			"type": "boolean",
			"default": true
		},
		"url": {
			"type": "string",
			"default": ""
		},
		"customSpeakerId": {
			"type": "number",
			"default": 0
		},
		"linkTo": {
			"type": "string",
			"default": "mail"
		},
		"customLinkIcon": {
			"type": "string",
			"default": ""
		}
	},
	"parent": ["ctx-events/details"],
	"render": "file:./render.php"
}
