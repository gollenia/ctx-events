{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-phone",
	"apiVersion": 3,
	"title": "Phone Field",
	"description": "Lets the user type a phone number.",
	"category": "widgets",
	"attributes": {
		"name": {
			"type": "string",
			"default": ""
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": true
		},
		"label": {
			"type": "string",
			"default": "Phone"
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"visibilityRule": {
			"type": "object",
			"default": null
		}
	},
	"parent": [
		"ctx-events/form-container"
	]
}