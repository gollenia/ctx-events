{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-phone",
	"apiVersion": 3,
	"title": "Phone Field",
	"description": "Lets the user type a phone number.",
	"category": "widgets",
	"attributes": {
		"name": {
			"type": "string",
			"default": "email"
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": true
		},
		"label": {
			"type": "string",
			"default": "Phone"
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"error": {
			"type": "string",
			"default": ""
		}
	},
	"parent": ["ctx-events/form-container"]
}
