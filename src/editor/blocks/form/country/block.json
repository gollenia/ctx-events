{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-country",
	"apiVersion": 3,
	"title": "Country",
	"description": "Lets the user select a country",
	"category": "widgets",
	"attributes": {
		"name": {
			"type": "string",
			"default": ""
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"defaultValue": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"error": {
			"type": "string",
			"default": ""
		},
		"region": {
			"type": "string",
			"default": "world"
		}
	},
	"parent": ["ctx-events/form-container"]
}
