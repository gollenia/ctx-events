{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-date",
	"apiVersion": 3,
	"title": "Date Field",
	"description": "Lets the user specify a date",
	"category": "widgets",
	"attributes": {
		"name": {
			"type": "string",
			"default": ""
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"min": {
			"type": "string",
			"default": ""
		},
		"max": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"defaultValue": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"visibilityRule": {
			"type": "object",
			"default": null
		}
	},
	"parent": [
		"ctx-events/form-container"
	]
}