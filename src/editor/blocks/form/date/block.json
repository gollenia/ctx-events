{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-date",
	"apiVersion": 3,
	"title": "Date Field",
	"description": "Lets the user specify a date",
	"category": "widgets",
	"attributes": {
		"fieldid": {
			"type": "string",
			"default": ""
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"min": {
			"type": "string",
			"default": ""
		},
		"max": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"help": {
			"type": "string",
			"default": ""
		},
		"error": {
			"type": "string",
			"default": ""
		}
	},
	"parent": ["ctx-events/form-container"]
}
