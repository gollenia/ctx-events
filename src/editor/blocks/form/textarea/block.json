{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-textarea",
	"apiVersion": 3,
	"title": "Text Area",
	"description": "Lets the user type a longer text",
	"category": "widgets",
	"attributes": {
		"name": {
			"type": "string",
			"default": ""
		},
		"context": {
			"type": "string",
			"default": ""
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": false
		},
		"pattern": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"rows": {
			"type": "number",
			"default": 3
		},
		"visibilityRule": {
			"type": "object",
			"default": null
		}
	},
	"parent": ["ctx-events/form-container"]
}
