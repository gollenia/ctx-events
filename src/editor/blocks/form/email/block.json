{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/form-email",
	"apiVersion": 3,
	"title": "Email Field",
	"description": "Lets the user type an email address.",
	"category": "widgets",
	"attributes": {
		"name": {
			"type": "string",
			"default": ""
		},
		"context": {
			"type": "string",
			"default": ""
		},
		"width": {
			"type": "number",
			"default": 6
		},
		"required": {
			"type": "boolean",
			"default": true
		},
		"label": {
			"type": "string",
			"default": ""
		},
		"placeholder": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"visibilityRule": {
			"type": "object",
			"default": null
		}
	},
	"parent": ["ctx-events/form-container"]
}
