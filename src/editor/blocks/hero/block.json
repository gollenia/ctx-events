{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/hero",
	"title": "Event Hero",
	"description": "Display a single event as a large hero section.",
	"apiVersion": 3,
	"category": "widgets",
	"attributes": {
		"selectedEvent": {
			"type": "number",
			"default": 0
		},
		"showExcerpt": {
			"type": "boolean",
			"default": true
		},
		"showLocation": {
			"type": "boolean",
			"default": true
		},
		"showButton": {
			"type": "boolean",
			"default": true
		},
		"buttonText": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": "split"
		}
	},
	"usesContext": ["postId", "postType"],
	"supports": {
		"align": ["wide", "full"],
		"anchor": true,
		"spacing": {
			"margin": ["top", "bottom"],
			"padding": ["top", "bottom", "left", "right"],
			"blockGap": true
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
