{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/featured-button",
	"apiVersion": 3,
	"title": "Featured Event Button",
	"description": "Render a theme-styled button linking to the featured event.",
	"category": "widgets",
	"icon": "button",
	"ancestor": ["ctx-events/featured-event"],
	"attributes": {
		"text": {
			"type": "string",
			"default": ""
		}
	},
	"usesContext": ["ctx-events/eventId", "postId", "postType"],
	"render": "file:./render.php",
	"editorScript": "file:./index.js"
}
