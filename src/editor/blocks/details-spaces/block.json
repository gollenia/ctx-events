{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"name": "ctx-events/details-spaces",
	"apiVersion": 3,
	"title": "Event Booking Spaces",
	"description": "Show the open spaces",
	"category": "widgets",
	"attributes": {
		"icon": {
			"type": "string",
			"default": "spaces_available"
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"warningThreshold": {
			"type": "number",
			"default": 5
		},
		"warningText": {
			"type": "string",
			"default": ""
		},
		"okText": {
			"type": "string",
			"default": ""
		},
		"showNumber": {
			"type": "boolean",
			"default": false
		},
		"showBookedUp": {
			"type": "boolean",
			"default": true
		},
		"bookedUpText": {
			"type": "string",
			"default": ""
		}
	},
	"parent": ["ctx-events/details"],
	"usesContext": ["postType", "postId"],
	"render": "file:./render.php"
}
