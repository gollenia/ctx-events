			"php": "8.4"
		},
		"allow-plugins": {
			"composer/installers": true,
			"pestphp/pest-plugin": true
		}
	},
	"require": {
		"php": "^8.4",
		"ext-gd": "^8.4",
		"ext-curl": "^8.4",
		"shuchkin/simplexlsxgen": "^1.4.11",
		"smhg/sepa-qr-data": "^2.0.1",
		"mpdf/mpdf": "^8.2.4",
		"chillerlan/php-qrcode": "^5.0.2",
		"mollie/mollie-api-php": "^2.75.0",
		"twig/twig": "^3.21",
		"symfony/http-foundation": "^7.2",
		"php-di/php-di": "^7.1"
	},
	"autoload": {
		"psr-4": {
			"Contexis\\Events\\": "app/"
		}
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"php-stubs/wordpress-stubs": "^6.7",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"pestphp/pest": "^4.1"
	}
