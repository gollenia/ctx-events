{
	"name": "contexis/events",
	"version": "6.7.0",
	"description": "Events Manager",
	"type": "project",
	"homepage": "http://www.kids-team.at",
	"readme": "readme.md",
	"license": "MIT",
	"authors": [
		{
			"name": "Thomas Gollenia",
			"email": "thomas@gollenia.at",
			"homepage": "http://www.gollenia.at",
			"role": "Developer"
		},
		{
			"name": "Matthias Demmin",
			"email": "matthias@kids-team.at",
			"role": "Manager"
		}
	],
	"config": {
		"platform": {
			"php": "8.4"
		},
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"require": {
		"php": "^8.2",
		"ext-gd": "^8.2",
		"ext-curl": "^8.2",
		"shuchkin/simplexlsxgen": "^1.4.11",
		"smhg/sepa-qr-data": "^2.0.1",
		"mpdf/mpdf": "^8.2.4",
		"timber/timber": "^2.2.0",
		"chillerlan/php-qrcode": "^5.0.2",
		"mollie/mollie-api-php": "^2.75.0"
	},
	"autoload": {
		"psr-4": {
			"Contexis\\Events\\Blocks\\": "classes/Blocks/",
			"Contexis\\Events\\Collections\\": "classes/Collections/",
			"Contexis\\Events\\Controllers\\": "classes/Controllers/",
			"Contexis\\Events\\PostTypes\\": "classes/PostTypes/",
			"Contexis\\Events\\Interfaces\\": "classes/Interfaces/",
			"Contexis\\Events\\Models\\": "classes/Models/",
			"Contexis\\Events\\Utilities\\": "classes/Utilities/",
			"Contexis\\Events\\Views\\": "classes/Views/",
			"Contexis\\Events\\Intl\\": "classes/Intl/",
			"Contexis\\Events\\Admin\\": "classes/Admin/",
			"Contexis\\Events\\Payment\\": "classes/Payment/"
		}
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"php-stubs/wordpress-stubs": "^6.7",
		"szepeviktor/phpstan-wordpress": "^2.0"
	}
}
